# TimeWeb App Platform ENV template
# Fill values and copy variables to TimeWeb App Platform services.
# Keep secrets private. Do not commit real values.
# For real credentials use a local file:
#   cp documentation/templates/timeweb-app-platform.env.example documentation/templates/timeweb-app-platform.env.local
# If you deploy in Docker mode, use:
#   documentation/templates/timeweb-docker-app-platform.env.example

############################
# SERVICE: backend/server
############################
NODE_ENV=production
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
ADMIN_TELEGRAM_IDS=577222108
ADMIN_VK_IDS=
TELEGRAM_WEBAPP_RETURN_URL=https://t.me/YOUR_BOT/app
BOT_POLLING_ENABLED=false
CART_SERVER_LOG_LEVEL=info
INTEGRATION_CACHE_TTL_MS=300000
APP_SECRETS_MASTER_KEY=base64:GENERATE_32_BYTE_RANDOM_KEY
DB_ADMIN_ROUTES_ENABLED=false
DB_ADMIN_ROUTE_SECRET_KEY=
DB_ADMIN_ROUTE_ALLOWED_IPS=

# iiko retry worker (optional, defaults exist)
IIKO_RETRY_WORKER_ENABLED=true
IIKO_RETRY_INTERVAL_MS=120000
IIKO_RETRY_BATCH_LIMIT=25
IIKO_RETRY_MAX_ATTEMPTS=5
IIKO_WEBHOOK_TOKEN=CHANGE_ME_STRONG_SECRET
IIKO_MENU_SYNC_WORKER_ENABLED=true
IIKO_MENU_SYNC_INTERVAL_MS=900000
IIKO_MENU_SYNC_BATCH_LIMIT=25
IIKO_MENU_SYNC_ALERT_MIN_CONSECUTIVE_FAILURES=2
IIKO_ALERTS_ENABLED=true
IIKO_WEBHOOK_ALERTS_ENABLED=true
IIKO_MENU_SYNC_ALERTS_ENABLED=true
IIKO_ALERTS_DEDUP_MS=900000
# Optional. For large external menus you can raise timeout and retry budget.
IIKO_EXTERNAL_MENU_TIMEOUT_MS=30000
IIKO_EXTERNAL_MENU_RETRY_ATTEMPTS=3
IIKO_EXTERNAL_MENU_RETRY_DELAY_MS=2000
# Optional override. By default alerts go only to super_admin from DB.
IIKO_ALERTS_TELEGRAM_IDS=
# Optional override. Usually auto-detected from explicit payment mappings in restaurant_integrations.
IIKO_PAYMENT_MODE=

# YooKassa test fallback (optional; production usually uses DB config per restaurant)
YOOKASSA_TEST_SHOP_ID=
YOOKASSA_TEST_SECRET_KEY=
YOOKASSA_TEST_CALLBACK_URL=https://YOUR_DOMAIN/api/payments/yookassa/webhook

# Geocoder (optional)
GEOCODER_PROVIDER=photon
VITE_YANDEX_GEOCODE_API_KEY=
GEOCODER_CACHE_TTL_MS=300000
GEOCODER_RATE_LIMIT_PER_IP=30
GEOCODER_RATE_LIMIT_WINDOW_MS=5000

# VK Mini App backend auth (optional)
VK_SECRET_KEY=
VK_SERVICE_KEY=

############################
# SERVICE: backend/bot
############################
NODE_ENV=production
BOT_TOKEN=
WEBAPP_URL=https://YOUR_DOMAIN
SERVER_API_URL=https://YOUR_DOMAIN/api
ADMIN_TELEGRAM_IDS=577222108
BOT_POLLING_ENABLED=true
API_PORT=4000
SUPPORT_URL_CACHE_TTL_MS=300000
BOT_RETRY_DELAY_MS=10000

############################
# SERVICE: frontend
############################
VITE_SERVER_API_URL=/api
VITE_ADMIN_API_URL=/api/cart
VITE_USE_SERVER_API=true
VITE_FORCE_SERVER_API=true
VITE_ADMIN_TELEGRAM_IDS=577222108
VITE_ADMIN_VK_IDS=
VITE_BASE_PATH=/

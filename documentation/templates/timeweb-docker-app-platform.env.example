# TimeWeb App Platform ENV template (Docker mode)
# Mode: one Docker app for frontend+backend (Dockerfile) + separate bot app (Dockerfile.bot)
# Keep real secrets only in local/private files.

########################################
# APP 1: mariko-app (Dockerfile)
# Repo Dockerfile: ./Dockerfile
########################################
# Runtime env for backend inside container:
NODE_ENV=production
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
ADMIN_TELEGRAM_IDS=577222108
ADMIN_VK_IDS=
TELEGRAM_WEBAPP_RETURN_URL=https://t.me/YOUR_BOT/app

# IMPORTANT: disable polling in backend app to avoid Telegram 409 conflicts.
BOT_POLLING_ENABLED=false

# Logging/perf
CART_SERVER_LOG_LEVEL=info
INTEGRATION_CACHE_TTL_MS=300000

# iiko retry worker (optional, defaults exist)
IIKO_RETRY_WORKER_ENABLED=true
IIKO_RETRY_INTERVAL_MS=120000
IIKO_RETRY_BATCH_LIMIT=25
IIKO_RETRY_MAX_ATTEMPTS=5

# YooKassa test fallback (optional; production usually uses DB config per restaurant)
YOOKASSA_TEST_SHOP_ID=
YOOKASSA_TEST_SECRET_KEY=
YOOKASSA_TEST_CALLBACK_URL=https://YOUR_DOMAIN/api/payments/yookassa/webhook

# Geocoder (optional)
GEOCODER_PROVIDER=photon
VITE_YANDEX_GEOCODE_API_KEY=
GEOCODER_CACHE_TTL_MS=300000
GEOCODER_RATE_LIMIT_PER_IP=30
GEOCODER_RATE_LIMIT_WINDOW_MS=5000

# Storage (optional)
YANDEX_STORAGE_ACCESS_KEY_ID=
YANDEX_STORAGE_SECRET_ACCESS_KEY=
YANDEX_STORAGE_BUCKET_NAME=
YANDEX_STORAGE_REGION=ru-central1
YANDEX_STORAGE_ENDPOINT=https://storage.yandexcloud.net
YANDEX_STORAGE_PUBLIC_URL=

# VK Mini App backend auth (optional)
VK_SECRET_KEY=
VK_SERVICE_KEY=

# Build args for Dockerfile (set in TimeWeb build settings, not runtime env):
# VITE_BASE_PATH=/tg/
# VITE_SERVER_API_URL=/tg/api
# VITE_CART_API_URL=/tg/api/cart/submit
# APP_BASE_PATH=/tg

########################################
# APP 2: mariko-bot (Dockerfile.bot)
# Repo Dockerfile: ./Dockerfile.bot
########################################
NODE_ENV=production
BOT_TOKEN=

# IMPORTANT: use /tg/ because main Docker app serves frontend under base path /tg/
WEBAPP_URL=https://YOUR_DOMAIN/tg/
SERVER_API_URL=https://YOUR_DOMAIN/api

ADMIN_TELEGRAM_IDS=577222108
BOT_POLLING_ENABLED=true

# API_PORT has priority over PORT. You can omit API_PORT on platforms that provide PORT.
API_PORT=4000
SUPPORT_URL_CACHE_TTL_MS=300000
BOT_RETRY_DELAY_MS=10000

